# Supabase Configuration (Frontend — Vite)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ============================================================================
# Supabase Edge Function Secrets
# These are NOT stored in .env — configure via: supabase secrets set KEY=VALUE
# Listed here for documentation purposes only.
# ============================================================================
# SUPABASE_SERVICE_ROLE_KEY  — auto-set by Supabase
# GEMINI_API_KEY             — Google Gemini API (parse-tariff-document, extract-invoice-data, process-tariff-sheet)
# GOOGLE_CLIENT_ID           — Google OAuth (sync-gmail)
# GOOGLE_CLIENT_SECRET       — Google OAuth (sync-gmail)
# CRON_SECRET                — Opaque token for authenticating cron/scheduled calls (sync-gmail)
# RESEND_WEBHOOK_SECRET      — Resend webhook signature verification (webhook-email)
# WHATSAPP_APP_SECRET        — Meta WhatsApp webhook signature verification (webhook-whatsapp)
# WHATSAPP_VERIFY_TOKEN      — Meta WhatsApp webhook verification token (webhook-whatsapp)
# WHATSAPP_PHONE_NUMBER_ID   — Meta WhatsApp Business phone number ID (send-message)
# WHATSAPP_ACCESS_TOKEN      — Meta WhatsApp Business API access token (send-message)
